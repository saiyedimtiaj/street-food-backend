// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String             @db.VarChar(100)
  email                   String             @unique @db.VarChar(255)
  password                String
  role                    String             @default("user") @db.VarChar(20)
  profile_photo           String?
  profile_photo_public_id String?
  bio                     String?
  is_active               Boolean?           @default(true)
  created_at              DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?          @default(now()) @db.Timestamptz(6)
  stores                  Store[]
  reviews                 Review[]
  suggestions             StoreSuggestion[]
  claims                  StoreClaim[]

  @@map("users")
}

model Store {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id              String?         @db.Uuid
  owner                 User?           @relation(fields: [owner_id], references: [id], onDelete: SetNull)
  name                  String          @db.VarChar(150)
  description           String?
  category              String?         @db.VarChar(100)
  address               String?
  latitude              Decimal         @db.Decimal(10, 8)
  longitude             Decimal         @db.Decimal(11, 8)
  cover_image           String?
  cover_image_public_id String?
  status                String?         @default("active") @db.VarChar(20)
  is_claimed            Boolean?        @default(false)
  created_at            DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?       @default(now()) @db.Timestamptz(6)
  gallery               StoreGallery[]
  foods                 Food[]
  reviews               Review[]
  replies               ReviewReply[]
  claims                StoreClaim[]

  @@map("stores")
}

model StoreGallery {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_id   String    @db.Uuid
  store      Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  image_url  String
  public_id  String
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("store_gallery")
}

model Food {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_id     String    @db.Uuid
  store        Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(150)
  description  String?
  price        Decimal   @db.Decimal(10, 2)
  image_url    String?
  is_available Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@map("foods")
}

model Review {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String        @db.Uuid
  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store_id   String        @db.Uuid
  store      Store         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  created_at DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at DateTime?     @default(now()) @db.Timestamptz(6)
  images     ReviewImage[]
  replies    ReviewReply[]

  @@unique([user_id, store_id])
  @@map("reviews")
}

model ReviewImage {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  review_id  String    @db.Uuid
  review     Review    @relation(fields: [review_id], references: [id], onDelete: Cascade)
  image_url  String
  public_id  String
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("review_images")
}

model ReviewReply {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  review_id  String    @db.Uuid
  review     Review    @relation(fields: [review_id], references: [id], onDelete: Cascade)
  store_id   String    @db.Uuid
  store      Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  reply_text String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("review_replies")
}

model StoreSuggestion {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  suggested_by String    @db.Uuid
  user         User      @relation(fields: [suggested_by], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(150)
  description  String?
  address      String?
  latitude     Decimal?  @db.Decimal(10, 8)
  longitude    Decimal?  @db.Decimal(11, 8)
  status       String?   @default("pending") @db.VarChar(20)
  admin_note   String?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@map("store_suggestions")
}

model StoreClaim {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_id   String    @db.Uuid
  store      Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  claimed_by String    @db.Uuid
  user       User      @relation(fields: [claimed_by], references: [id], onDelete: Cascade)
  message    String?
  status     String?   @default("pending") @db.VarChar(20)
  admin_note String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([store_id, claimed_by])
  @@map("store_claims")
}
